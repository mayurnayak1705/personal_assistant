# Choose auto, openai, anthropic, or local. Auto prefers configured cloud providers.
LLM_PROVIDER=auto

# Configure at least one model provider
OPENAI_API_KEY=replace_with_your_openai_api_key
# ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# LLM_MAX_TOKENS=4096

# Local OpenAI-compatible server (for example Ollama or LM Studio).
# Set LLM_PROVIDER=local to use it. The model must support tool/function calling.
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_MODEL=llama3.1:8b
# LOCAL_LLM_API_KEY=local
# LOCAL_LLM_TIMEOUT=120

# Embeddings use OpenAI when available and otherwise Chroma's local embedding.
# EMBEDDING_PROVIDER=auto
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_assistant_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_your_postgres_password

# Local timezone
APP_TIMEZONE=Asia/Kolkata
# Optional stable key for this local installation's single user
# DEEP_THOUGHT_USER_ID=local-user

# Google integrations
GMAIL_FROM_EMAIL=you@example.com
GOOGLE_CALENDAR_ID=primary
# DEEP_THOUGHT_CREDENTIALS_DIR=~/.deep-thought/credentials

# Optional local database paths
# EXPENSE_DB_PATH=./data/expenses.db
# CHROMA_PATH=./data/chroma
# WHATSMEOW_SESSION_DB=./data/whatsmeow-session.db
# WHATSMEOW_LOG_DB=./data/whatsmeow-message-log.db

# Memory/debug behavior
WORKING_CONTEXT_TTL_MINUTES=360
DEEP_THOUGHT_DEBUG=1
